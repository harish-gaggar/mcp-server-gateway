# Google Drive + Docs MCP server credentials.
#
# Choose ONE of the modes below.

# --- Open mode: shared OAuth access token ---
# A Google OAuth access token carrying Drive + Docs scopes, used as a Bearer
# credential. Quick for local testing, but access tokens expire in ~1 hour.
# Generate one at https://developers.google.com/oauthplayground with scopes:
#   https://www.googleapis.com/auth/drive
#   https://www.googleapis.com/auth/documents
GOOGLE_ACCESS_TOKEN=

# --- Open mode: service account ---
# Path (inside the container) to a mounted service-account JSON key file.
# The server mints its own access tokens for GOOGLE_SCOPES.
# GOOGLE_SERVICE_ACCOUNT_FILE=/app/service-account.json
# Optional: impersonate a Google Workspace user (domain-wide delegation).
# GOOGLE_IMPERSONATE_SUBJECT=you@yourdomain.com
# GOOGLE_SCOPES=https://www.googleapis.com/auth/drive https://www.googleapis.com/auth/documents

# --- Secure mode: per-user OAuth via the gateway ---
# When true, the server uses each request's forwarded Google access token.
# Set this (not the above) when running behind the OAuth-protected gateway.
# GDRIVE_SECURE_MODE=true
