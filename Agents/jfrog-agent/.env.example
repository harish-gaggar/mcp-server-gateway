# ─────────────────────────────────────────────────────────────────────────────
# JFrog LangGraph Agent — configuration
#
# Copy to `.env` and fill in. Everything here is read by jfrog_agent/settings.py.
# ─────────────────────────────────────────────────────────────────────────────

# ── MCP Gateway ──────────────────────────────────────────────────────────────
# Base URL used for all server-side calls (discovery, token, MCP proxy).
# Local run:      http://localhost:8090
# In a container: http://host.docker.internal:8090  (set in docker-compose)
JFROG_AGENT_GATEWAY_URL=http://localhost:8090
# Only used to build the browser authorization link. In a container this stays
# http://localhost:8090 so YOUR browser can reach it, while the calls above use
# host.docker.internal. Leave unset to default to JFROG_AGENT_GATEWAY_URL.
# JFROG_AGENT_GATEWAY_PUBLIC_URL=http://localhost:8090
# Namespace of the Artifactory MCP server behind the gateway.
JFROG_AGENT_MCP_NAMESPACE=artifactory

# ── Per-user OAuth ───────────────────────────────────────────────────────────
# The gateway performs per-user OAuth (Google -> JFrog OIDC exchange). The agent
# runs the browser authorization ONCE, then caches the token below and reuses it.
# Local loopback port the agent listens on to receive the OAuth redirect.
JFROG_AGENT_OAUTH_CALLBACK_PORT=8777
# Bind host for that callback server. Use 0.0.0.0 in a container (set in
# docker-compose) so the mapped port is reachable; 127.0.0.1 for local runs.
JFROG_AGENT_OAUTH_BIND_HOST=127.0.0.1
# Where the cached gateway token is stored (one-time auth, reused across runs).
JFROG_AGENT_TOKEN_CACHE=~/.jfrog-agent/token.json
# OAuth scopes requested from the gateway.
JFROG_AGENT_OAUTH_SCOPE=openid email

# ── Client identity (telemetry: agent vs coding assistant) ───────────────────
# Recorded by the gateway as `gateway.client_type` so monitoring can tell the
# agent's traffic apart from interactive tools like Cursor.
JFROG_AGENT_CLIENT_TYPE=agent
# The clientInfo.name reported during MCP initialize / DCR client_name.
JFROG_AGENT_CLIENT_NAME=jfrog-langgraph-agent

# ── LLM (optional) ───────────────────────────────────────────────────────────
# Provider: openai | anthropic | none. With `none` (or no API key) the agent
# uses a deterministic keyword planner so it still runs offline.
JFROG_AGENT_LLM_PROVIDER=openai
JFROG_AGENT_LLM_MODEL=gpt-4o-mini
# OPENAI_API_KEY=sk-...
# ANTHROPIC_API_KEY=sk-ant-...

# ── Safety / scope ───────────────────────────────────────────────────────────
# Comma-separated repository allowlist. Empty = all repos allowed for READ-only
# operations. Write/destructive tools are always restricted to this list.
JFROG_AGENT_REPO_ALLOWLIST=
# Max rows any AQL query may return (hard cap enforced by the validated builder).
JFROG_AGENT_AQL_MAX_RESULTS=200
# Read-only mode: refuse to execute any write/destructive tool (Phase 1 default).
JFROG_AGENT_READ_ONLY=true
# Directory for the immutable audit trail (one JSONL record per run).
JFROG_AGENT_AUDIT_DIR=~/.jfrog-agent/audit

# ── Agent observability (optional) ───────────────────────────────────────────
# If set, the agent exports its own OTLP traces to the same collector as the
# gateway (defaults to the gateway's collector). Leave blank to disable.
# JFROG_AGENT_OTEL_ENDPOINT=http://localhost:4318

# ── Durable agent memory (threads, checkpoints, LLM telemetry) ───────────────
# Backend: sqlite (default, local file — no services) or spanner (Cloud Spanner
# or the local emulator). Threads + LangGraph checkpoints survive restarts, so
# you can resume past conversations tomorrow.
JFROG_AGENT_MEMORY_BACKEND=sqlite
JFROG_AGENT_MEMORY_DB=~/.jfrog-agent/memory.db
JFROG_AGENT_CHECKPOINTS_DB=~/.jfrog-agent/checkpoints.db
# Spanner (only used when MEMORY_BACKEND=spanner). Point SPANNER_EMULATOR_HOST at
# the local emulator; leave unset to use real Cloud Spanner (needs GCP creds).
# Local run against the emulator started by docker-compose: localhost:9110
# SPANNER_EMULATOR_HOST=localhost:9110
JFROG_AGENT_SPANNER_PROJECT=jfrog-agent-local
JFROG_AGENT_SPANNER_INSTANCE=jfrog-agent
JFROG_AGENT_SPANNER_DATABASE=agent-memory
