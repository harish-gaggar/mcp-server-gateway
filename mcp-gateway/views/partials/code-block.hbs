{{!--
  Copyable code block

  Parameters:
    text  {string}  - The code/command text to display and copy
--}}
<div class="flex items-center gap-2 rounded-lg bg-gray-50 px-4 py-3 ring-1 ring-gray-200">
  <code class="flex-1 font-mono text-xs text-gray-800 break-all">{{text}}</code>
  <button
    type="button"
    aria-label="Copy"
    onclick="copyCode(this)"
    data-text="{{text}}"
    class="copy-btn shrink-0 rounded p-1 text-gray-400 transition-colors hover:bg-gray-200 hover:text-gray-600"
  >
    <svg class="icon-copy h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
      <path stroke-linecap="round" stroke-linejoin="round" d="M8 16H6a2 2 0 01-2-2V6a2 2 0 012-2h8a2 2 0 012 2v2m-6 12h8a2 2 0 002-2v-8a2 2 0 00-2-2h-8a2 2 0 00-2 2v8a2 2 0 002 2z" />
    </svg>
    <svg class="icon-check hidden h-4 w-4 text-green-500" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
      <path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" />
    </svg>
  </button>
</div>
