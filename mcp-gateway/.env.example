# Generate with: openssl rand -base64 32
TOKEN_ENCRYPTION_KEY=

# JFrog Artifactory settings (used by the artifactory-mcp container)
ARTIFACTORY_BASE_URL=https://your-instance.jfrog.io/artifactory

# Preferred auth: a JFrog access/identity token used as a Bearer credential.
# Works with a company-issued access token AND a free-tier identity token
# (JFrog Platform UI -> Profile -> Generate an Identity Token).
ARTIFACTORY_ACCESS_TOKEN=

# Legacy fallback only (deprecated, older self-hosted API keys). Leave blank
# if you are using ARTIFACTORY_ACCESS_TOKEN above.
# ARTIFACTORY_API_KEY=

# =========================================================================
# Secure mode (per-user OAuth). Uncomment to enable gateway OAuth + consent.
# =========================================================================
# OAUTH_CONFIG_FILE=./configs/secure-oauth-config.yml
# MCP_CONFIG_FILE=./configs/secure-mcp-config.yml
# GOOGLE_OAUTH_CLIENT_ID=
# GOOGLE_OAUTH_CLIENT_SECRET=

# True per-user JFrog RBAC: name of the OIDC integration in JFrog Platform.
# When set, artifactory-mcp exchanges each user's forwarded Google id_token for
# a user-scoped JFrog token (no shared token). Must match the JFrog provider name.
# ARTIFACTORY_OIDC_PROVIDER_NAME=google-mcp-gateway

# Public origin clients use to reach the gateway (http://localhost:8090 for local).
# GATEWAY_BASE_URL=http://localhost:8090

# Observability: export gateway traces + metrics to a local OpenTelemetry Collector.
# OTEL_EXPORTER_OTLP_ENDPOINT=http://otel-collector:4318
