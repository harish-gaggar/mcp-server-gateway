{
  "name": "mcp-gateway",
  "version": "2.1.6",
  "private": true,
  "type": "module",
  "main": "src/main.ts",
  "scripts": {
    "start": "tsx --import ./src/instrumentation.ts ./src/main.ts -c ./configs/local-host.yml",
    "dev": "tsx --watch --import ./src/instrumentation.ts ./src/main.ts -c ./configs/local-host.yml",
    "compose:up": "docker compose up -d --build",
    "compose:down": "docker compose down",
    "compose:logs": "docker compose logs -f",
    "test:e2e": "node scripts/e2e-test.mjs",
    "build": "node ./scripts/build.js",
    "test": "run-p lint typecheck vitest",
    "test:unit:ci": "npm run test",
    "lint": "eslint src test",
    "lint:fix": "npm run lint -- --fix",
    "typecheck": "tsc --noEmit",
    "vitest": "vitest --no-watch",
    "vitest:dev": "vitest --watch"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/cookie-parser": "^1.4.10",
    "@types/express": "^5.0.6",
    "@types/ms": "^2.1.0",
    "@types/node": "^24.12.2",
    "@vitest/coverage-v8": "^4.1.2",
    "@vitest/ui": "^4.1.2",
    "esbuild": "^0.27.0",
    "eslint": "^10.2.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.5",
    "globals": "^17.4.0",
    "npm-run-all": "^4.1.5",
    "prettier": "^3.8.1",
    "tsx": "^4.21.0",
    "typescript": "^6.0.2",
    "typescript-eslint": "^8.58.0",
    "vitest": "^4.1.2"
  },
  "dependencies": {
    "@hono/node-server": "^1.19.12",
    "@ladjs/graceful": "^5.0.0",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@opentelemetry/api": "^1.9.1",
    "@opentelemetry/exporter-metrics-otlp-proto": "^0.214.0",
    "@opentelemetry/exporter-trace-otlp-proto": "^0.214.0",
    "@opentelemetry/resources": "^2.6.1",
    "@opentelemetry/sdk-metrics": "^2.6.1",
    "@opentelemetry/sdk-node": "^0.214.0",
    "@opentelemetry/sdk-trace-node": "^2.6.1",
    "@opentelemetry/semantic-conventions": "^1.40.0",
    "@types/cors": "^2.8.19",
    "bcryptjs": "^3.0.3",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.6",
    "dayjs": "^1.11.20",
    "dotenv": "^17.4.0",
    "es-toolkit": "^1.45.1",
    "eventsource-parser": "^3.0.6",
    "express": "^5.2.1",
    "express-handlebars": "^9.0.1",
    "express-rate-limit": "^8.4.1",
    "ioredis": "^5.10.1",
    "jose": "^6.2.2",
    "ms": "^2.1.3",
    "openid-client": "^6.8.2",
    "pino": "^10.3.1",
    "pino-http": "^11.0.0",
    "pino-pretty": "^13.1.3",
    "proxy-agent": "^8.0.1",
    "rate-limit-redis": "^4.3.1",
    "yaml": "^2.8.3",
    "zod": "^4.3.6"
  }
}
